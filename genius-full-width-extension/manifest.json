{
  "manifest_version": 3,
  "name": "Genius Full Width",
  "version": "1.0.0",
  "description": "Removes clutter and expands the lyrics area to full width.",
  "content_scripts": [
    {
      "matches": ["*://genius.com/*-lyrics"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
