{
  "manifest_version": 3,
  "name": "Genius UI Enhancer",
  "version": "1.1.0",
  "description": "Removes clutter and offers customization to Genius lyric pages.",
  "content_scripts": [
    {
      "matches": [
        "*://genius.com/*",
        "*://www.genius.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
